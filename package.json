{
  "name": "react-vite-tailwind",
  "description": "Aplicacion de escritorio para inventario de tienda de bebes.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "author": "Codex",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:start": "npm run build && electron .",
    "exe": "node scripts/build-exe.mjs",
    "exe:watch": "node scripts/watch-exe.mjs"
  },
  "dependencies": {
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "clsx": "2.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "3.4.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "chokidar": "^5.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  },
  "build": {
    "appId": "com.babystore.inventorypwa",
    "productName": "Baby Store Inventory",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "baby-store-inventory-${version}.exe"
    }
  }
}
